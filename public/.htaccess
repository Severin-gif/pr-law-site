RewriteEngine On

# API route for PHP runtime (without Node proxy)
RewriteRule ^api/request-audit/?$ api/request-audit.php [L,QSA]

# Serve existing files/directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback
RewriteRule . index.html [L]
