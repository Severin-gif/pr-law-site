RewriteEngine On

# Serve existing files/directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback
RewriteRule . index.html [L]

<IfModule mod_headers.c>
  # index.html should never be cached aggressively to guarantee fresh hashed bundles.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Hashed Vite assets can be cached for a long time.
  <FilesMatch "\.(js|css|woff2?|ttf|svg|png|jpe?g|gif|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
